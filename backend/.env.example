# FastAPI
APP_NAME=adhd-coach-api
DEBUG=true

# CORS: comma-separated origins (browser dev server)
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Internal callbacks (Fetch.ai → your backend). Generate a long random string locally.
INTERNAL_API_KEY=replace-with-long-random-string

# Optional: public API key for demo auth (header X-API-Key) — implement when ready
# DEMO_API_KEY=

# MongoDB Atlas — paste connection string from Atlas; include database name in path, e.g. .../adhd_coach?...
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/adhd_coach?appName=Cluster0

# Google Gen AI (Gemini) — google-genai SDK; never commit real keys
# GEMINI_API_KEY=
# Optional model id (default Gemini 3 Flash preview — override if AI Studio shows a different id)
# GEMINI_MODEL=gemini-3-flash-preview
# Gemini 3 thinking depth (latency vs quality): minimal | low | medium | high (omit for API default)
# GEMINI_THINKING_LEVEL=minimal
# Log timing per Gemini call (default true)
# GEMINI_LOG_TIMING=true

# Twilio WhatsApp — from Twilio console; FROM is sandbox or approved sender (whatsapp:+...)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Fetch.ai — uAgents / Agentverse (never commit secrets)
# Use the sponsor workshop to register an agent that POSTs to /internal/reminders/fire
# Optional: FETCH_AI_* vars per official docs
# FETCH_AI_API_KEY=
# FETCH_AI_PROJECT_ID=
